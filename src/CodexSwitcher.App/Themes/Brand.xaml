<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Identidade própria (acento teal) sobre a base Fluent + cantos arredondados. -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <!-- Tema escuro -->
            <Color x:Key="BrandAccentColor">#1FD1C1</Color>
            <Color x:Key="BrandAccentColorHover">#3CDDCE</Color>
            <Color x:Key="BrandAccentColorPressed">#16A99C</Color>
            <Color x:Key="BrandOnAccentColor">#06231F</Color>
            <Color x:Key="BrandAccentSoftColor">#2620E0C8</Color>
            <Color x:Key="BrandGradientStart">#1FD1C1</Color>
            <Color x:Key="BrandGradientEnd">#2E9BFF</Color>
            <Color x:Key="HealthWarnColor">#F5B301</Color>
            <Color x:Key="HealthDangerColor">#FF6B5B</Color>
            <Color x:Key="HealthOkColor">#39D98A</Color>
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <!-- Tema claro -->
            <Color x:Key="BrandAccentColor">#0C8F82</Color>
            <Color x:Key="BrandAccentColorHover">#0E9E90</Color>
            <Color x:Key="BrandAccentColorPressed">#0A7A6F</Color>
            <Color x:Key="BrandOnAccentColor">#FFFFFF</Color>
            <Color x:Key="BrandAccentSoftColor">#1A0C8F82</Color>
            <Color x:Key="BrandGradientStart">#0FB5A4</Color>
            <Color x:Key="BrandGradientEnd">#2E7DFF</Color>
            <Color x:Key="HealthWarnColor">#B5860B</Color>
            <Color x:Key="HealthDangerColor">#C33B2E</Color>
            <Color x:Key="HealthOkColor">#1C9E5F</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Brushes derivados (resolvem a cor do tema ativo) -->
    <SolidColorBrush x:Key="BrandAccentBrush" Color="{ThemeResource BrandAccentColor}" />
    <SolidColorBrush x:Key="BrandAccentHoverBrush" Color="{ThemeResource BrandAccentColorHover}" />
    <SolidColorBrush x:Key="BrandAccentPressedBrush" Color="{ThemeResource BrandAccentColorPressed}" />
    <SolidColorBrush x:Key="BrandOnAccentBrush" Color="{ThemeResource BrandOnAccentColor}" />
    <SolidColorBrush x:Key="BrandAccentSoftBrush" Color="{ThemeResource BrandAccentSoftColor}" />
    <SolidColorBrush x:Key="HealthWarnBrush" Color="{ThemeResource HealthWarnColor}" />
    <SolidColorBrush x:Key="HealthDangerBrush" Color="{ThemeResource HealthDangerColor}" />
    <SolidColorBrush x:Key="HealthOkBrush" Color="{ThemeResource HealthOkColor}" />

    <LinearGradientBrush x:Key="BrandGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{ThemeResource BrandGradientStart}" Offset="0" />
        <GradientStop Color="{ThemeResource BrandGradientEnd}" Offset="1" />
    </LinearGradientBrush>

    <!-- Cantos arredondados generosos (pedido do usuário) -->
    <CornerRadius x:Key="CardCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="ControlCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="OverlayCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="BadgeCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="AvatarCornerRadius">12</CornerRadius>

</ResourceDictionary>
