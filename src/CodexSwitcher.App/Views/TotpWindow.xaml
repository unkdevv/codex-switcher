<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CodexSwitcher.App.Views.TotpWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="2FA">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Padding="24" RowDefinitions="Auto,Auto,Auto,*,Auto" RowSpacing="18">

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12">
            <Border Width="40" Height="40" CornerRadius="12" VerticalAlignment="Center"
                    Background="{ThemeResource BrandGradientBrush}">
                <FontIcon Glyph="&#xE72E;" FontSize="19" Foreground="{ThemeResource BrandOnAccentBrush}" />
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="HeaderText" FontSize="18" FontWeight="Bold" />
                <TextBlock x:Name="SubtitleText" Opacity="0.7" FontSize="12" TextWrapping="Wrap" />
            </StackPanel>
        </StackPanel>

        <!-- Secret input -->
        <StackPanel Grid.Row="1" Spacing="6">
            <TextBlock x:Name="SecretLabel" FontWeight="SemiBold" FontSize="13" />
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="SecretBox" Grid.Column="0" TextChanged="OnSecretChanged"
                         IsSpellCheckEnabled="False" FontFamily="Consolas" />
                <Button x:Name="PasteButton" Grid.Column="1" Click="OnPasteClick">
                    <FontIcon Glyph="&#xE77F;" FontSize="15" />
                </Button>
            </Grid>
            <TextBlock x:Name="ErrorText" Foreground="{ThemeResource HealthDangerBrush}" FontSize="12"
                       TextWrapping="Wrap" Visibility="Collapsed" />
        </StackPanel>

        <!-- Code card -->
        <Border Grid.Row="2" x:Name="CodeCard" Visibility="Collapsed"
                CornerRadius="{StaticResource CardCornerRadius}" Padding="22,20" BorderThickness="1.5"
                BorderBrush="{ThemeResource BrandAccentBrush}" Background="{ThemeResource BrandAccentSoftBrush}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock x:Name="AccountText" Opacity="0.75" FontSize="12"
                               TextTrimming="CharacterEllipsis" Visibility="Collapsed" />
                    <Button x:Name="CodeButton" Click="OnCodeClick" HorizontalAlignment="Left"
                            Background="Transparent" BorderThickness="0" Padding="4,2" Margin="-4,0"
                            CornerRadius="8">
                        <TextBlock x:Name="CodeText" FontSize="42" FontWeight="Bold" FontFamily="Consolas"
                                   Foreground="{ThemeResource BrandAccentBrush}" />
                    </Button>
                    <TextBlock x:Name="ExpiryText" Opacity="0.7" FontSize="12" />
                </StackPanel>
                <Grid Grid.Column="1" Width="56" Height="56" VerticalAlignment="Center">
                    <ProgressRing x:Name="Countdown" IsIndeterminate="False" Value="100"
                                  Width="56" Height="56" Foreground="{ThemeResource BrandAccentBrush}" />
                    <TextBlock x:Name="SecondsText" HorizontalAlignment="Center" VerticalAlignment="Center"
                               FontWeight="SemiBold" FontSize="15" />
                </Grid>
            </Grid>
        </Border>

        <!-- Empty hint (no valid secret yet) -->
        <StackPanel Grid.Row="3" x:Name="EmptyHint" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Spacing="10" MaxWidth="320">
            <FontIcon Glyph="&#xE928;" FontSize="30" Opacity="0.35" />
            <TextBlock x:Name="EmptyHintText" TextAlignment="Center" Opacity="0.55" FontSize="13"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="4" ColumnDefinitions="*,Auto" VerticalAlignment="Bottom">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center"
                        x:Name="CopiedPanel" Visibility="Collapsed">
                <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource HealthOkBrush}" />
                <TextBlock x:Name="CopiedText" Foreground="{ThemeResource HealthOkBrush}"
                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
            </StackPanel>
            <Button Grid.Column="1" x:Name="CopyButton" Click="OnCopyClick" Visibility="Collapsed"
                    Background="{ThemeResource BrandAccentBrush}" Foreground="{ThemeResource BrandOnAccentBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                    <TextBlock x:Name="CopyButtonText" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
