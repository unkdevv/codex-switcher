<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CodexSwitcher.App.Views.PrivateBrowserTab"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" Padding="8,6" ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="6">
            <Button Grid.Column="0" x:Name="BackButton" Click="OnBackClick" IsEnabled="False">
                <SymbolIcon Symbol="Back" />
            </Button>
            <Button Grid.Column="1" x:Name="ForwardButton" Click="OnForwardClick" IsEnabled="False">
                <SymbolIcon Symbol="Forward" />
            </Button>
            <Button Grid.Column="2" x:Name="ReloadButton" Click="OnReloadClick" IsEnabled="False">
                <SymbolIcon Symbol="Refresh" />
            </Button>
            <TextBox Grid.Column="3" x:Name="AddressBox" VerticalAlignment="Center"
                     IsSpellCheckEnabled="False" KeyDown="OnAddressKeyDown" IsEnabled="False" />
            <ProgressRing Grid.Column="4" x:Name="LoadingRing" Width="16" Height="16"
                          IsActive="False" VerticalAlignment="Center" />
            <Button Grid.Column="5" x:Name="TwoFactorButton" Click="OnTwoFactorClick">
                <FontIcon Glyph="&#xE72E;" FontSize="14" />
            </Button>
        </Grid>

        <WebView2 Grid.Row="1" x:Name="Web" />
    </Grid>
</UserControl>
