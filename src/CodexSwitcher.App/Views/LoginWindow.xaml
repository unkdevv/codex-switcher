<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CodexSwitcher.App.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Entrar em uma conta Codex">
    <Grid RowDefinitions="Auto,*,Auto" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
            <ProgressRing Grid.Column="0" x:Name="Spinner" IsActive="True" Width="20" Height="20" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" FontWeight="SemiBold" />
                <TextBlock x:Name="CleanNoteText" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
            </StackPanel>
            <Border Grid.Column="2" x:Name="CodePanel" Visibility="Collapsed" VerticalAlignment="Center"
                    CornerRadius="8" Padding="12,6" Background="{ThemeResource BrandAccentSoftBrush}">
                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock x:Name="CodeLabel" VerticalAlignment="Center" Opacity="0.8" />
                    <TextBlock x:Name="CodeText" FontFamily="Consolas" FontSize="18" FontWeight="Bold"
                               Foreground="{ThemeResource BrandAccentBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>

        <WebView2 Grid.Row="1" x:Name="Web" />

        <Grid Grid.Row="2" Padding="16,12" ColumnDefinitions="*,Auto">
            <TextBlock Grid.Column="0" x:Name="HintText" VerticalAlignment="Center" Opacity="0.7"
                       FontSize="12" TextWrapping="Wrap" />
            <Button Grid.Column="1" x:Name="CancelButton" Click="OnCancelClick" />
        </Grid>
    </Grid>
</Window>
