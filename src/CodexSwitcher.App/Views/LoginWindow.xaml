<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CodexSwitcher.App.Views.LoginWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:CodexSwitcher.App.Views"
    Title="Entrar em uma conta Codex">
    <Grid RowDefinitions="Auto,*,Auto" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="16,12" ColumnSpacing="12">
            <ProgressRing Grid.Column="0" x:Name="Spinner" IsActive="True" Width="20" Height="20" />
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" FontWeight="SemiBold" />
                <TextBlock x:Name="CleanNoteText" FontSize="12" Opacity="0.7" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="2" x:Name="TwoFactorButton" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE72E;" FontSize="14" />
                <Button.Flyout>
                    <!-- Popup preso ao botão (como o de uma extensão de navegador), não uma janela nova:
                         fechar/clicar fora só esconde; o TotpPanel continua vivo com o segredo e o
                         código em contagem, então reabrir não reinicia nada. -->
                    <Flyout Placement="BottomEdgeAlignedRight">
                        <views:TotpPanel x:Name="TotpPanel" Width="380" />
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <WebView2 Grid.Row="1" x:Name="Web" />

        <Grid Grid.Row="2" Padding="16,12" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBlock Grid.Column="0" x:Name="HintText" VerticalAlignment="Center" Opacity="0.7"
                       FontSize="12" TextWrapping="Wrap" />
            <Button Grid.Column="1" x:Name="InstallWebView2Button" Click="OnInstallWebView2Click"
                    Visibility="Collapsed"
                    Background="{ThemeResource BrandAccentBrush}" Foreground="{ThemeResource BrandOnAccentBrush}" />
            <Button Grid.Column="2" x:Name="CancelButton" Click="OnCancelClick" />
        </Grid>
    </Grid>
</Window>
