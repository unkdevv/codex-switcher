<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CodexSwitcher.App.Views.AccountsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CodexSwitcher.App.ViewModels"
    xmlns:conv="using:CodexSwitcher.App.Support"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <conv:BadgeToTextConverter x:Key="BadgeText" />
        <conv:BadgeToBrushConverter x:Key="BadgeBrush" />
        <conv:ActiveToBackgroundConverter x:Key="ActiveBg" />
        <conv:CardBorderBrushConverter x:Key="CardBorder" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar (drag region) -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48" ColumnDefinitions="Auto,*">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" Margin="16,0"
                        VerticalAlignment="Center">
                <Image x:Name="AppIcon" Width="22" Height="22" />
                <TextBlock Text="Codex Switcher" VerticalAlignment="Center" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Header + toolbar -->
        <Grid Grid.Row="1" Margin="24,12,24,8" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{x:Bind Loc.AccountsHeader}" FontSize="26" FontWeight="Bold" />
                <TextBlock Text="{x:Bind Loc.AccountsSubtitle}" Opacity="0.7" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="{x:Bind Loc.SearchPlaceholder}" Width="200" QueryIcon="Find"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                                Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource InvBoolToVis}}" />
                <Button Command="{x:Bind ViewModel.RefreshAllCommand}"
                        ToolTipService.ToolTip="{x:Bind Loc.RefreshAllTooltip}"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource InvBoolToVis}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        <TextBlock Text="{x:Bind Loc.RefreshAll}" />
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.AddAccountCommand}"
                        Background="{ThemeResource BrandAccentBrush}" Foreground="{ThemeResource BrandOnAccentBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE710;" FontSize="14" />
                        <TextBlock Text="{x:Bind Loc.SignInOAuth}" />
                    </StackPanel>
                </Button>
                <Button Click="OnOpen2FaClick" ToolTipService.ToolTip="{x:Bind Loc.TwoFactorTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72E;" FontSize="14" />
                        <TextBlock Text="{x:Bind Loc.TwoFactorButton}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- InfoBar -->
        <InfoBar Grid.Row="2" Margin="24,4"
                 IsOpen="{x:Bind ViewModel.InfoOpen, Mode=TwoWay}"
                 Severity="{x:Bind ViewModel.InfoSeverity, Mode=OneWay}"
                 Title="{x:Bind ViewModel.InfoTitle, Mode=OneWay}"
                 Message="{x:Bind ViewModel.InfoMessage, Mode=OneWay}" />

        <!-- Content -->
        <Grid Grid.Row="3" Margin="0,4,0,0">

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420" Spacing="16"
                        Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center"
                        Background="{ThemeResource BrandGradientBrush}">
                    <FontIcon Glyph="&#xE77B;" FontSize="34" Foreground="{ThemeResource BrandOnAccentBrush}" />
                </Border>
                <TextBlock Text="{x:Bind Loc.EmptyTitle}" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock TextAlignment="Center" Opacity="0.7" TextWrapping="Wrap" Text="{x:Bind Loc.EmptyBody}" />
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <Button Command="{x:Bind ViewModel.AddAccountCommand}"
                            Background="{ThemeResource BrandAccentBrush}" Foreground="{ThemeResource BrandOnAccentBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="14" />
                            <TextBlock Text="{x:Bind Loc.SignInOAuth}" />
                        </StackPanel>
                    </Button>
                    <Button Command="{x:Bind ViewModel.AdoptActiveCommand}" Content="{x:Bind Loc.ImportCurrent}" />
                </StackPanel>
            </StackPanel>

            <!-- Account list -->
            <Grid Visibility="{x:Bind ViewModel.ShowEmptyState, Mode=OneWay, Converter={StaticResource InvBoolToVis}}"
                  RowDefinitions="Auto,*">

                <InfoBar Grid.Row="0" Margin="24,0,24,8" IsOpen="{x:Bind ViewModel.ShowAdoptPrompt, Mode=OneWay}"
                         IsClosable="False" Severity="Informational"
                         Title="{x:Bind Loc.AdoptTitle}"
                         Message="{x:Bind Loc.AdoptMessage}">
                    <InfoBar.ActionButton>
                        <Button Content="{x:Bind Loc.Import}" Command="{x:Bind ViewModel.AdoptActiveCommand}" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Accounts}"
                          SelectionMode="None" Padding="24,0,24,24"
                          ScrollViewer.HorizontalScrollMode="Disabled"
                          CanReorderItems="True" CanDragItems="True" AllowDrop="True"
                          DragItemsCompleted="OnAccountsReordered">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,12" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:AccountItemViewModel">
                            <Border CornerRadius="{StaticResource CardCornerRadius}" BorderThickness="1.5" Padding="16"
                                    BorderBrush="{x:Bind Converter={StaticResource CardBorder}}"
                                    Background="{x:Bind IsActive, Converter={StaticResource ActiveBg}}">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="14">
                                    <Border Grid.Column="0" Width="48" Height="48"
                                            CornerRadius="{StaticResource AvatarCornerRadius}"
                                            Background="{ThemeResource BrandGradientBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Initials}" FontWeight="Bold" FontSize="18"
                                                   Foreground="{ThemeResource BrandOnAccentBrush}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="16"
                                                       VerticalAlignment="Center" />
                                            <Border CornerRadius="{StaticResource BadgeCornerRadius}" BorderThickness="1"
                                                    Padding="8,1" VerticalAlignment="Center"
                                                    BorderBrush="{x:Bind Badge, Converter={StaticResource BadgeBrush}}">
                                                <TextBlock Text="{x:Bind Badge, Converter={StaticResource BadgeText}}"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{x:Bind Badge, Converter={StaticResource BadgeBrush}}" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{x:Bind Subtitle}" Opacity="0.7" FontSize="13" />
                                        <TextBlock Text="{x:Bind HealthText}" Opacity="0.6" FontSize="12" />
                                        <TextBlock Text="{x:Bind LastSwitchedText}" Opacity="0.5" FontSize="12"
                                                   ToolTipService.ToolTip="{x:Bind LastSwitchedTooltip}" />
                                    </StackPanel>

                                    <Button Grid.Column="2" VerticalAlignment="Center" Click="OnSwitchClick"
                                            Visibility="{x:Bind CanSwitch, Converter={StaticResource BoolToVis}}"
                                            Background="{ThemeResource BrandAccentBrush}"
                                            Foreground="{ThemeResource BrandOnAccentBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE8AB;" FontSize="14" />
                                            <TextBlock Text="{x:Bind SwitchLabel}" />
                                        </StackPanel>
                                    </Button>
                                    <Border Grid.Column="2" VerticalAlignment="Center" Padding="10,6"
                                            CornerRadius="{StaticResource ControlCornerRadius}"
                                            Visibility="{x:Bind IsActive, Converter={StaticResource BoolToVis}}"
                                            Background="{ThemeResource BrandAccentSoftBrush}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE73E;" FontSize="14" Foreground="{ThemeResource BrandAccentBrush}" />
                                            <TextBlock Text="{x:Bind InUseLabel}" Foreground="{ThemeResource BrandAccentBrush}"
                                                       FontWeight="SemiBold" FontSize="13" />
                                        </StackPanel>
                                    </Border>

                                    <Button Grid.Column="3" VerticalAlignment="Center" Background="Transparent"
                                            BorderThickness="0" ToolTipService.ToolTip="{x:Bind MoreActionsLabel}">
                                        <FontIcon Glyph="&#xE712;" FontSize="16" />
                                        <Button.Flyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="{x:Bind RefreshNowLabel}" Click="OnRefreshItemClick">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72C;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{x:Bind RenameLabel}" Click="OnRenameItemClick">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{x:Bind MarkUsedLabel}" Click="OnMarkUsedClick"
                                                                Visibility="{x:Bind IsMarkedUsed, Converter={StaticResource InvBoolToVis}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE73E;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{x:Bind UnmarkUsedLabel}" Click="OnUnmarkUsedClick"
                                                                Visibility="{x:Bind IsMarkedUsed, Converter={StaticResource BoolToVis}}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE894;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="{x:Bind MarkReLoginLabel}" Click="OnMarkReLoginClick">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7BA;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="{x:Bind RemoveLabel}" Click="OnRemoveItemClick">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Flyout>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Busy overlay -->
            <Grid Background="#80000000"
                  Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="{StaticResource CardCornerRadius}" Padding="28"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <ProgressRing IsActive="True" Width="28" Height="28" />
                        <TextBlock Text="{x:Bind ViewModel.BusyText, Mode=OneWay}" VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
